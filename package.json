{
  "name": "keyra-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --webpack -p 3030",
    "dev:turbo": "next dev --turbopack -p 3030",
    "dev:3000": "next dev --webpack -p 3000",
    "dev:turbo:3000": "next dev --turbopack -p 3000",
    "build": "prisma generate && next build",
    "start": "prisma migrate deploy && npm run db:seed:deploy-catalog && next start -H 0.0.0.0 -p ${PORT:-3030}",
    "start:3000": "prisma migrate deploy && npm run db:seed:deploy-catalog && next start -H 0.0.0.0 -p 3000",
    "lint": "eslint",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && NODE_OPTIONS=\"--max-old-space-size=8192\" next dev --webpack -p 3030",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:sync:protection": "prisma db execute --schema prisma/schema.prisma --file prisma/migrations/20260522120000_keyra_user_protection/migration.sql",
    "db:sync:simsecure": "node scripts/apply-keyra-migrations-simsecure.mjs",
    "db:seed": "prisma db seed",
    "db:seed:auth-feed": "tsx prisma/seedAuthenticationFeed.ts",
    "db:seed:local-latest-auth": "tsx prisma/seedLocalLatestAuth.ts",
    "db:check:feed": "tsx prisma/checkFeedDb.ts",
    "db:seed:deploy-catalog": "tsx prisma/seedDeployCatalog.ts",
    "db:seed:regions-countries": "tsx prisma/seedRegionsCountries.ts",
    "db:seed:admin-users": "tsx prisma/seedAdminUsers.ts",
    "db:seed:site-footer": "tsx prisma/seedSiteFooter.ts",
    "db:seed:deployment-graph": "tsx prisma/seedDeploymentGraph.ts",
    "db:import:telcos": "tsx prisma/importKeyraTelcosFromXlsx.ts",
    "db:export:telcos-catalog": "tsx prisma/exportKeyraTelcosCatalog.ts",
    "db:seed:sat-protocols": "tsx prisma/seedSatProtocolRegistry.ts",
    "db:seed:world-countries": "tsx prisma/seedWorldAuthenticationCountries.ts",
    "import:sat-core": "tsx scripts/importSatCoreProtocols.ts",
    "generate:world-map": "tsx scripts/generateWorldWireframe.ts",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@prisma/client": "^6.19.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.3",
    "libphonenumber-js": "^1.13.2",
    "next": "16.2.1",
    "prisma": "^6.19.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "three": "^0.184.0",
    "tsx": "^4.20.5",
    "world-countries": "^5.1.0"
  },
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "1.32.0",
    "lightningcss-darwin-x64": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
