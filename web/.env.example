# simsecure-auth-backend — same SimSecure auth API you already deploy (e.g. Railway). Not hosted on keyra.ie.
# Production example: https://auth.ciright.pro
# Inlined at build time for /hosted-login fetches.
NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL=https://auth.ciright.pro

# /verify-device: POST goes to auth /auth/phone-verify/browser-start; IPIFICATION_* on Keyra is fallback only.
IPIFICATION_BASE_URL=https://api.stage.ipification.com
IPIFICATION_CLIENT_ID=
IPIFICATION_REDIRECT_URI=
NEXT_PUBLIC_IPIFICATION_CLIENT_ID=
NEXT_PUBLIC_IPIFICATION_REDIRECT_URI=https://keyra.ie/callback

# Optional: local testing with auth mock (must match ENABLE_LOCAL_MOCK_VERIFY on auth backend).
# NEXT_PUBLIC_ENABLE_LOCAL_MOCK_VERIFY=true
