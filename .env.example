# Contact — browser XHR to Ciright (shows m1391103 / m1357069 in DevTools). Ciright must allow your origin via CORS (like ciright.pro).
# NEXT_PUBLIC_CIRIGHT_API_SUBJECTS_URL=https://www.myciright.com/Ciright/api/commonrestapi/m1391103
# NEXT_PUBLIC_CIRIGHT_API_LEAD_URL=https://www.myciright.com/Ciright/api/commonrestapi/m1357069
# NEXT_PUBLIC_CIRIGHT_CONTACT_SUBSCRIPTION_ID=9049255
# NEXT_PUBLIC_CIRIGHT_CONTACT_VERTICAL_ID=2948
# NEXT_PUBLIC_CIRIGHT_CONTACT_APP_ID=2953
# NEXT_PUBLIC_CIRIGHT_CONTACT_SUBJECTS_SPHERE_URL=sim-secure-admin.htm
# NEXT_PUBLIC_CIRIGHT_CONTACT_SUBMIT_SPHERE_URL=sim-secure-registration.htm
# NEXT_PUBLIC_CIRIGHT_CONTACT_FROM_MAIL=no-reply@ciright.com
# NEXT_PUBLIC_CIRIGHT_CONTACT_LEAD_SOURCE_ID=1

# simsecure-auth-backend (your existing auth service URL—not keyra.ie).
NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL=https://auth.ciright.pro

# /verify-device (hosted-login QR): browser POSTs to simsecure-auth POST /auth/phone-verify/browser-start.
# IPification redirect_uri (must match auth backend IPIFICATION_*): use https://keyra.ie/api/ipification/oidc-return (POST form_post + GET).
# Keyra IPIFICATION_* below is only for the local fallback route if NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL is unset.
IPIFICATION_BASE_URL=https://api.stage.ipification.com
IPIFICATION_CLIENT_ID=
IPIFICATION_REDIRECT_URI=
NEXT_PUBLIC_IPIFICATION_CLIENT_ID=
# Fallback only if auth backend URL unset; must match IPIFICATION_REDIRECT_URI on auth + IPification app.
NEXT_PUBLIC_IPIFICATION_REDIRECT_URI=https://keyra.ie/api/ipification/oidc-return

# Optional: local mock (auth backend ENABLE_LOCAL_MOCK_VERIFY=true)
# NEXT_PUBLIC_ENABLE_LOCAL_MOCK_VERIFY=true
