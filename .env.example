# Keyra web — local development
#
# Copy to `.env` (gitignored) and adjust.

# Prisma — PostgreSQL (local Docker example below, Railway uses the Postgres plugin URL).
DATABASE_URL="postgresql://keyra:keyra@localhost:5432/keyra?schema=public"

# Optional: serve admin UI/API only on this hostname (e.g. admin.keyra.ie). When set, requests to
# /admin/* and /api/admin/* on www or apex are redirected here. Omit locally (use http://localhost:3030/admin).
# KEYRA_ADMIN_HOST="admin.keyra.ie"
# KEYRA_ADMIN_PUBLIC_ORIGIN="https://admin.keyra.ie"

# Admin: at least one of the following must be set for production.
# — JWT signing secret (min 32 chars). In development, a built-in dev secret is used if unset.
KEYRA_ADMIN_JWT_SECRET=""

# — Legacy break-glass shared secret (optional). If set, can be used on /admin/login in the
#   "Break-glass token" field to obtain a service JWT, or sent as raw Bearer/cookie for APIs.
KEYRA_ADMIN_TOKEN="change-me"

# Optional: actor labels written into audit/status history rows
KEYRA_ADMIN_ACTOR_ID="admin"
KEYRA_ADMIN_ACTOR_ROLE="Global Admin"

# Seed script (`npm run db:seed`): password for all demo AdminUser rows (min 8 chars recommended).
# If unset, seed uses ChangeMeSeed!123.
SEED_ADMIN_PASSWORD="ChangeMeSeed!123"

# Optional: used in server access verification emails
NEXT_PUBLIC_KEYRA_SITE_URL="http://localhost:3030"

# Optional: Mailchimp Transactional (Mandrill) for access-request emails
# MANDRILL_API_KEY=""
# MANDRILL_FROM_EMAIL=""
