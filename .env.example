# simsecure-auth-backend (your existing auth service URL—not keyra.ie).
NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL=https://auth.ciright.pro

# /verify-device (mobile QR) — browser opens this host in the authorize URL. Use stage to avoid api.ipification.com:
#   NEXT_PUBLIC_IPIFICATION_BASE_URL=https://api.stage.ipification.com
# Use stage client_id + redirect_uri registered in the IPification stage console. For token exchange to succeed,
# set the same base URL on simsecure-auth-backend: IPIFICATION_BASE_URL=https://api.stage.ipification.com
NEXT_PUBLIC_IPIFICATION_BASE_URL=https://api.stage.ipification.com
NEXT_PUBLIC_IPIFICATION_CLIENT_ID=
NEXT_PUBLIC_IPIFICATION_REDIRECT_URI=https://get-started.ciright.pro/callback

# Optional: local mock (auth backend ENABLE_LOCAL_MOCK_VERIFY=true)
# NEXT_PUBLIC_ENABLE_LOCAL_MOCK_VERIFY=true
