# Keyra Global Deployment — standalone public site
#
# Copy to `.env` and point DATABASE_URL at the same Postgres as the main Keyra app.

# Shared deployment registry database (same as Keyra root).
DATABASE_URL="postgresql://keyra:keyra@localhost:5432/keyra?schema=public"

# This site's public origin (local dev default: port 3050).
NEXT_PUBLIC_GLOBAL_DEPLOYMENT_URL="http://localhost:3050"

# Main Keyra marketing site (for ecosystem links).
NEXT_PUBLIC_KEYRA_SITE_URL="http://localhost:3030"

# Optional: server access verification emails
# MANDRILL_API_KEY=""
# MANDRILL_FROM_EMAIL=""
