generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeploymentStatus {
  IDENTIFIED
  INSTITUTIONAL_AWARENESS
  TVIP
  OPERATIONAL
}

enum TargetType {
  COUNTRY
  TELCO
}

enum ServerEnvironment {
  PROD
  STAGE
  TEST
}

enum VerificationMethod {
  EMAIL_OTP
  SSO
  INVITE_ONLY
}

enum EmployeeType {
  TYPE_1
}

enum RequestVerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

enum RequestApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StatusHistoryTargetType {
  REGION
  COUNTRY
  TELCO
  SERVER_NODE
}

/** Mirrors institutional roles from the deployment doctrine (v1). */
enum DeploymentAdminRole {
  GLOBAL_ADMIN
  REGIONAL_ADMIN
  COUNTRY_ADMIN
  TELCO_ADMIN
  COMPLIANCE_REVIEWER
  READ_ONLY
}

model AdminUser {
  id           String               @id @default(cuid())
  email        String               @unique
  displayName  String?
  phoneE164    String?              @unique
  passwordHash String
  role         DeploymentAdminRole
  /** JSON: { "regionIds"?: string[], "countryIds"?: string[], "telcoIds"?: string[] } */
  scopeJson    Json?
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model Region {
  id             String   @id @default(cuid())
  continentCode  String
  subregionCode  String
  name           String
  slug           String   @unique
  mapKey         String
  sortOrder      Int      @default(0)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  countries CountryDeployment[]
}

model CountryDeployment {
  id                      String            @id @default(cuid())
  regionId                String
  region                  Region            @relation(fields: [regionId], references: [id], onDelete: Cascade)
  name                    String
  iso2                    String
  iso3                    String
  flagAssetKey            String
  population              Int?
  populationDisplay       String?
  countrySubdomain        String
  officialReferenceDomain String?
  status                  DeploymentStatus
  statusNote              String?
  sourceLabel             String?
  sourceUrl               String?
  sourceVerifiedAt        DateTime?
  sortOrder               Int               @default(0)
  isPublished             Boolean           @default(false)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  /** WGS84 — authoritative map anchor when set (admin). */
  latitude   Float?
  longitude  Float?
  /** Pixel offsets in map space (1000×500 projection) for fine placement. */
  visualOffsetX Float @default(0)
  visualOffsetY Float @default(0)

  deploymentStage          String?
  infrastructureHealth     Int?
  uptimePercentage         Float?
  nodeHealth               Int?
  authVolume               Int?
  clusterRegion            String?
  lastSyncAt               DateTime?
  aiAgentEnabled           Boolean @default(false)
  deploymentScore          Int?
  satProtocolCoverage      String?
  simEsimStatus            String?
  govIntegrationStatus     String?
  apiStatus                String?
  regulatoryReadiness      String?
  riskStatus               String?
  connectedAppsCount       Int?

  telcos TelcoDeployment[]

  @@unique([countrySubdomain])
  @@index([regionId])
  @@index([iso2])
}

model TelcoDeployment {
  id                 String            @id @default(cuid())
  countryId          String
  country            CountryDeployment @relation(fields: [countryId], references: [id], onDelete: Cascade)
  name               String
  slug               String
  subscribers        Int?
  subscribersDisplay String?
  telcoSubdomain     String
  officialDomain     String?
  status             DeploymentStatus
  statusNote         String?
  sourceLabel        String?
  sourceUrl          String?
  sourceVerifiedAt   DateTime?
  sortOrder          Int               @default(0)
  isPublished        Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([countryId, slug])
  @@index([countryId])
}

model ServerNode {
  id              String            @id @default(cuid())
  targetType      TargetType
  targetId        String
  fqdn            String
  environment     ServerEnvironment
  healthcheckUrl  String?
  status          DeploymentStatus
  lastHeartbeatAt DateTime?
  metadataJson    Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([targetType, targetId])
}

model AccessDomainRule {
  id                   String             @id @default(cuid())
  targetType           TargetType
  targetId             String
  allowedEmailDomain   String
  verificationMethod   VerificationMethod @default(EMAIL_OTP)
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([targetType, targetId])
}

model ServerAccessRequest {
  id                     String                    @id @default(cuid())
  targetType             TargetType
  targetId               String
  workEmail              String
  employeeType           EmployeeType              @default(TYPE_1)
  requestReason          String?
  verificationStatus     RequestVerificationStatus @default(PENDING)
  verificationTokenHash  String?
  verificationExpiresAt  DateTime?
  approvalStatus         RequestApprovalStatus     @default(PENDING)
  approvedBy             String?
  approvedAt             DateTime?
  rejectedBy             String?
  rejectedAt             DateTime?
  rejectionReason        String?
  auditRef               String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  @@index([targetType, targetId])
  @@index([workEmail])
}

model StatusHistory {
  id             String                   @id @default(cuid())
  targetType     StatusHistoryTargetType
  targetId       String
  previousStatus DeploymentStatus?
  nextStatus     DeploymentStatus
  changedBy      String
  changedAt      DateTime                 @default(now())
  reason         String?

  @@index([targetType, targetId])
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorId     String?
  actorRole   String?
  entityType  String
  entityId    String
  action      String
  payloadJson Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model DeploymentApp {
  id          String   @id
  label       String
  description String   @db.Text
  href        String   @db.Text
  gensparkUrl String?  @db.Text
  temporaryUrl String? @db.Text
  section     String   @default("Operations")
  sortOrder   Int      @default(0)
  isPrivate   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([section, sortOrder])
  @@index([isPrivate])
  @@index([isActive])
}

/** Registry of app category names (shown in create/edit app and filters). */
model DeploymentAppCategory {
  name      String   @id
  sortOrder Int      @default(100)
  createdAt DateTime @default(now())
}

enum MaterialMediaKind {
  IMAGE
  VIDEO
  GIF
  OTHER
}

/** Admin-managed media assets (images, videos, GIFs) stored in S3. */
model AdminMaterial {
  id            String            @id @default(cuid())
  title         String
  description   String?           @db.Text
  url           String            @db.Text
  s3Key         String            @db.Text
  mimeType      String
  mediaKind     MaterialMediaKind
  fileName      String
  fileSizeBytes Int
  sortOrder     Int               @default(0)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([isActive, sortOrder])
  @@index([mediaKind])
}

enum DataRoomDocumentKind {
  PDF
  TEXT
  WORD
  SPREADSHEET
  PRESENTATION
  OTHER
}

/** Admin data room documents (PDF, text, Office, etc.) stored in S3. */
model AdminDataRoom {
  id            String              @id @default(cuid())
  title         String
  description   String?             @db.Text
  url           String              @db.Text
  s3Key         String              @db.Text
  mimeType      String
  documentKind  DataRoomDocumentKind
  fileName      String
  fileSizeBytes Int
  sortOrder     Int                 @default(0)
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([isActive, sortOrder])
  @@index([documentKind])
}

/** Optional display profile for Keyra marketing / app session (keyed by phone from login). */
model KeyraSiteUserProfile {
  id          String   @id @default(cuid())
  phoneE164 String   @unique
  displayName String?
  email       String?
  country     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/** Per-user protection dashboard state (identity watch scans). */
model KeyraUserProtection {
  phoneE164    String    @id
  lastScanAt   DateTime?
  scanStatus   String    @default("clear")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

/** Known devices seen for a Keyra user (from session user-agent). */
model KeyraUserDevice {
  id            String   @id @default(cuid())
  phoneE164     String
  label         String
  deviceKind    String
  userAgentHash String
  lastActiveAt  DateTime @default(now())
  isCurrent     Boolean  @default(false)

  @@unique([phoneE164, userAgentHash])
  @@index([phoneE164])
}

/** Trusted locations inferred or added for a Keyra user. */
model KeyraTrustedLocation {
  id          String   @id @default(cuid())
  phoneE164   String
  label       String
  regionHint  String?
  lastSeenAt  DateTime @default(now())
  isCurrent   Boolean  @default(false)

  @@index([phoneE164])
}

/** Admin-configured country weights for keyra.ie “Latest authentications” demo feed. */
model AuthenticationCountry {
  id                      String   @id @default(cuid())
  countryName             String
  officialName            String?  @db.Text
  iso2                    String   @unique @db.VarChar(2)
  iso3                    String?  @unique @db.VarChar(3)
  isoNumeric              String?  @db.VarChar(3)
  /** Broad area (e.g. Europe, Americas) — used for filters and feed region fallback. */
  region                  String
  subRegion               String?  @db.Text
  capitalCity             String?  @db.Text
  flagEmoji               String?  @db.VarChar(8)
  flagAssetPath           String?  @db.Text
  phoneCountryCode        String?  @db.VarChar(32)
  currencyCode            String?  @db.VarChar(3)
  currencyName            String?  @db.Text
  primaryLanguage         String?  @db.Text
  /** Catalog row “live”; homepage Latest authentications requires this **and** `authenticationEnabled`. */
  active                  Boolean  @default(true)
  /** AUTH column in admin; homepage Latest authentications requires this **and** `active`. */
  authenticationEnabled   Boolean  @default(true)
  /** Relative weight before normalization to 100% in the feed engine. Default 5 for global seed. */
  percentageWeight        Float    @default(5)
  displayPriority         Int      @default(0)
  notes                     String?  @db.Text
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([active, region])
  @@index([active, authenticationEnabled])
  @@index([subRegion])
  @@index([displayPriority])
}

/** SAT protocol registry + Latest authentications feed pool + protocol detail modal (global SAT-Core). */
model SatProtocol {
  id                   String   @id @default(cuid())
  protocolName         String
  protocolCode         String   @unique
  /** URL-style slug (e.g. sat-mfa); not used in feed pair keys. */
  protocolSlug         String?  @unique
  protocolCategory     String
  shortDescription     String?  @db.Text
  longDescription      String?  @db.Text
  /** When true (“live” in admin), protocol is eligible for the public Latest authentications feed (uniform random among actives). */
  active               Boolean  @default(true)
  /** Admin/registry weight; feed does not bias by this field. */
  percentageWeight     Float    @default(60)
  protocolMemo         String   @default("")
  protocolUrlEnabled   Boolean  @default(false)
  protocolUrl          String?
  allowProtocolLink    Boolean  @default(false)
  /** Home vs roaming split for H/R display (must sum to ~100). Default 40 / 60. */
  homePercentage        Float    @default(40)
  roamingPercentage     Float    @default(60)
  securityClassification String  @default("STANDARD") @db.VarChar(24)
  flagEnterprise        Boolean  @default(true)
  flagGovernment        Boolean  @default(true)
  flagTelco             Boolean  @default(true)
  flagConsumer          Boolean  @default(true)
  flagAiAgent           Boolean  @default(true)
  displayOrder          Int      @default(0)
  iconKey               String?  @db.VarChar(64)
  colorTheme            String?  @db.VarChar(32)
  /** 1–5 scale for admin / UI trust badge. */
  trustLevel            Int      @default(4)
  riskReductionScore    Int      @default(0)
  globalAvailability    Boolean  @default(true)
  apiReady              Boolean  @default(true)
  auditRequired         Boolean  @default(true)
  consentRequired       Boolean  @default(true)
  zeroKnowledgeCompatible Boolean @default(false)
  simOrEsimRequired     Boolean  @default(false)
  deviceBindingRequired Boolean  @default(false)
  createdBySystem       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([active])
  @@index([protocolCategory])
  @@index([displayOrder])
}

/** Singleton row — use id "default" in application code. */
model AuthenticationFeedSetting {
  id                       String   @id
  feedEnabled              Boolean  @default(true)
  initialRecordsCount      Int      @default(50)
  batchSize                Int      @default(50)
  fetchThreshold             Int      @default(30)
  sessionUniquenessLimit     Int      @default(2000)
  maskingEnabled           Boolean  @default(true)
  obfuscationEnabled       Boolean  @default(false)
  maxRecordsPerSession     Int      @default(50000)
  animationSpeedMs       Int      @default(400)
  refreshBehavior          String   @default("append")
  defaultRegionWeightPreset String? @db.Text
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

/** Server-side session for paginated / weighted auth feed generation. */
model AuthenticationFeedSession {
  id                    String   @id @default(cuid())
  sessionUuid           String   @unique
  userFingerprintHash   String?
  renderedCount         Int      @default(0)
  uniquenessEpoch       Int      @default(0)
  pairsUsedJson         Json     @default("[]")
  rngNonce              Int      @default(0)
  createdAt             DateTime @default(now())
  expiresAt             DateTime

  @@index([expiresAt])
}

enum SiteFooterLinkSection {
  ON_THIS_SITE
  KEYRA_APPS
}

enum SiteSocialPlatform {
  LINKEDIN
  TWITTER
  INSTAGRAM
  YOUTUBE
  GITHUB
  CUSTOM
}

/** Singleton footer brand copy and section labels (keyra.ie + connected sites). */
model SiteFooterSettings {
  id              String   @id @default("default")
  logoSrc         String?
  description     String   @db.Text
  onThisSiteLabel String   @default("On this site")
  keyraAppsLabel  String   @default("Keyra apps")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SiteFooterLink {
  id           String                @id @default(cuid())
  section      SiteFooterLinkSection
  /** Deployment app id for ON_THIS_SITE links; null on KEYRA_APPS rows. */
  siteAppId    String?
  label        String
  href         String                @db.Text
  description  String?               @db.Text
  isExternal   Boolean               @default(false)
  internalPath String?
  sortOrder    Int                   @default(0)
  isPublished  Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([section, siteAppId, sortOrder])
}

model SiteFooterSocialLink {
  id          String             @id @default(cuid())
  platform    SiteSocialPlatform @default(CUSTOM)
  label       String
  url         String             @db.Text
  sortOrder   Int                @default(0)
  isPublished Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([sortOrder])
}

// ─── Global Agent World Architecture ─────────────────────────────────────────

/** Domain layer: Ciright parent → Keyra bridge → Marketplace sovereign portal. */
enum AgentDomainLayer {
  CIRIGHT_PARENT
  KEYRA_BRIDGE
  MARKETPLACE
}

enum AgentWorldType {
  TELCO
  GOVERNMENT
  UNIVERSITY
  BANKING
  ENTERPRISE
  HEALTHCARE
}

enum AgentOperationalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  MARKETPLACE_READY
  SUBSCRIBED
  DEPLOYING
  ACTIVE
  SUSPENDED
  REVOKED
}

enum AgentIndustryVertical {
  TELECOM
  GOVERNMENT
  BANKING
  UNIVERSITY
  HEALTHCARE
  ENTERPRISE
  INFRASTRUCTURE
  REGULATORY
}

/** Civilization-scale operational graph entity kinds (intrinsic index). */
enum IntrinsicIndexEntityKind {
  PERSON
  IDENTITY
  DEVICE
  SIM
  SUBSCRIBER
  AGENT
  TASK
  ORGANIZATION
  TENANT_WORLD
  COUNTRY
  REGULATORY_BOUNDARY
  KNOWLEDGE_PACK
  INTEGRATION
  PARENT_AGENT
  KEYRA_AGENT
  TENANT_AGENT
}

enum OperationalGraphRelation {
  INHERITS_FROM
  DEPLOYED_TO
  ATTACHED_TO
  CONNECTED_TO
  GOVERNS
  EXECUTES
  AUDITS
  CONTAINS
  BELONGS_TO
  REGULATED_BY
}

/** Parent agent design — agents.ciright.com (no tenant transactional data). */
model CirightParentAgent {
  id                      String                @id @default(cuid())
  parentAgentId           String                @unique
  name                    String
  slug                    String                @unique
  description             String                @db.Text
  operationalCategory     String
  industryVertical        AgentIndustryVertical
  workflowDefinitionJson  Json?
  orchestrationLogicJson  Json?
  policyEngineJson        Json?
  permissionStructureJson Json?
  executionTemplateJson   Json?
  deploymentStandardJson  Json?
  isPublished             Boolean               @default(false)
  sortOrder               Int                   @default(0)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  keyraAgents KeyraDeploymentAgent[]

  @@index([industryVertical])
  @@index([operationalCategory])
}

/** Keyra deployment bridge — ciright.agents.keyra.ie (no tenant operational data). */
model KeyraDeploymentAgent {
  id                       String                 @id @default(cuid())
  keyraAgentId             String                 @unique
  parentAgentId            String
  parentAgent              CirightParentAgent     @relation(fields: [parentAgentId], references: [id], onDelete: Restrict)
  name                     String
  slug                     String                 @unique
  description              String                 @db.Text
  domainLayer              AgentDomainLayer       @default(KEYRA_BRIDGE)
  industryVertical         AgentIndustryVertical
  deploymentClassification String?
  subscriptionPackage      String?
  /** ISO-3166 alpha-2 codes where this deployment agent applies. */
  countryIso2s             String[]               @default([])
  deploymentReadiness      AgentOperationalStatus @default(DRAFT)
  isMarketplaceApproved    Boolean                @default(false)
  sortOrder                Int                    @default(0)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  tenantInstances    TenantAgentInstance[]
  knowledgePackLinks KeyraAgentKnowledgePack[]

  @@index([parentAgentId])
  @@index([industryVertical])
  @@index([deploymentReadiness])
}

/** Sovereign operational environment — agents.keyra.ie tenant world. */
model AgentWorld {
  id                      String                 @id @default(cuid())
  worldId                 String                 @unique
  name                    String
  slug                    String                 @unique
  description             String                 @db.Text
  worldType               AgentWorldType
  industryVertical        AgentIndustryVertical
  countryIso2             String?
  organizationName        String?
  sovereignRegion         String?
  dataResidencyRule       String?
  complianceControlsJson  Json?
  governanceStructureJson Json?
  operationalRulesJson    Json?
  regionalBoundariesJson  Json?
  status                  AgentOperationalStatus @default(DRAFT)
  isActive                Boolean                @default(false)
  countryDeploymentId     String?
  telcoDeploymentId       String?
  sortOrder               Int                    @default(0)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  tenantInstances    TenantAgentInstance[]
  knowledgePackLinks AgentWorldKnowledgePack[]
  integrations       AgentWorldIntegration[]
  graphEdges         OperationalGraphEdge[]

  @@index([worldType])
  @@index([industryVertical])
  @@index([countryIso2])
  @@index([status])
}

/** Customer operational agent instance (lineage visible upstream; data stays in world). */
model TenantAgentInstance {
  id              String                 @id @default(cuid())
  instanceId      String                 @unique
  keyraAgentId    String
  keyraAgent      KeyraDeploymentAgent   @relation(fields: [keyraAgentId], references: [id], onDelete: Restrict)
  agentWorldId    String
  agentWorld      AgentWorld             @relation(fields: [agentWorldId], references: [id], onDelete: Cascade)
  displayName     String
  description     String?                @db.Text
  status          AgentOperationalStatus @default(DEPLOYING)
  permissionsJson Json?
  /** Inheritance metadata only — no tenant operational payloads. */
  lineageJson     Json?
  deployedAt      DateTime?
  activatedAt     DateTime?
  sortOrder       Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  tasks AgentOperationalTask[]

  @@index([keyraAgentId])
  @@index([agentWorldId])
  @@index([status])
}

/** Modular intelligence pack attachable to worlds and deployment agents. */
model KnowledgePack {
  id                      String                 @id @default(cuid())
  packId                  String                 @unique
  name                    String
  slug                    String                 @unique
  description             String                 @db.Text
  packCategory            String
  industryVertical        AgentIndustryVertical?
  countryIso2             String?
  approvedKnowledgeJson   Json?
  workflowStructuresJson  Json?
  promptStructuresJson    Json?
  operationalRulesJson    Json?
  integrationMappingsJson Json?
  complianceGuidanceJson  Json?
  isPublished             Boolean                @default(false)
  sortOrder               Int                    @default(0)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  worldLinks      AgentWorldKnowledgePack[]
  keyraAgentLinks KeyraAgentKnowledgePack[]

  @@index([packCategory])
  @@index([industryVertical])
}

model AgentWorldKnowledgePack {
  id              String   @id @default(cuid())
  agentWorldId    String
  knowledgePackId String
  attachedAt      DateTime @default(now())
  attachedBy      String?

  agentWorld    AgentWorld    @relation(fields: [agentWorldId], references: [id], onDelete: Cascade)
  knowledgePack KnowledgePack @relation(fields: [knowledgePackId], references: [id], onDelete: Cascade)

  @@unique([agentWorldId, knowledgePackId])
}

model KeyraAgentKnowledgePack {
  id              String   @id @default(cuid())
  keyraAgentId    String
  knowledgePackId String
  attachedAt      DateTime @default(now())

  keyraAgent    KeyraDeploymentAgent @relation(fields: [keyraAgentId], references: [id], onDelete: Cascade)
  knowledgePack KnowledgePack        @relation(fields: [knowledgePackId], references: [id], onDelete: Cascade)

  @@unique([keyraAgentId, knowledgePackId])
}

model AgentWorldIntegration {
  id              String                 @id @default(cuid())
  integrationId   String                 @unique
  agentWorldId    String
  name            String
  integrationType String
  endpointUrl     String?                @db.Text
  status          AgentOperationalStatus @default(DRAFT)
  configJson      Json?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  agentWorld AgentWorld @relation(fields: [agentWorldId], references: [id], onDelete: Cascade)

  @@index([agentWorldId])
}

/** Operational execution task reference (metadata only — no tenant payloads upstream). */
model AgentOperationalTask {
  id                    String    @id @default(cuid())
  taskId                String    @unique
  tenantAgentInstanceId String
  taskType              String
  status                String    @default("pending")
  lineageRef            String?
  scheduledAt           DateTime?
  completedAt           DateTime?
  createdAt             DateTime  @default(now())

  tenantAgentInstance TenantAgentInstance @relation(fields: [tenantAgentInstanceId], references: [id], onDelete: Cascade)

  @@index([tenantAgentInstanceId])
  @@index([status])
}

/** Intrinsic index — every governed object is indexed for lineage and orchestration. */
model IntrinsicIndexEntry {
  id           String                   @id @default(cuid())
  entityKind   IntrinsicIndexEntityKind
  entityRef    String
  displayLabel String
  domainLayer  AgentDomainLayer?
  /** When true, only lineage/orchestration metadata may leave the tenant world. */
  lineageOnly  Boolean                  @default(true)
  agentWorldId String?
  metadataJson Json?
  indexedAt    DateTime                 @default(now())

  @@unique([entityKind, entityRef])
  @@index([entityKind])
  @@index([domainLayer])
  @@index([agentWorldId])
}

/** Civilization-scale operational relationship graph. */
model OperationalGraphEdge {
  id           String                   @id @default(cuid())
  relation     OperationalGraphRelation
  fromKind     IntrinsicIndexEntityKind
  fromRef      String
  toKind       IntrinsicIndexEntityKind
  toRef        String
  agentWorldId String?
  lineageOnly  Boolean                  @default(true)
  metadataJson Json?
  createdAt    DateTime                 @default(now())

  agentWorld AgentWorld? @relation(fields: [agentWorldId], references: [id], onDelete: SetNull)

  @@index([fromKind, fromRef])
  @@index([toKind, toRef])
  @@index([agentWorldId])
  @@index([relation])
}

/** Deployment and governance events across agent domain layers. */
model AgentDeploymentEvent {
  id           String                  @id @default(cuid())
  eventType    String
  domainLayer  AgentDomainLayer
  entityKind   String
  entityId     String
  agentWorldId String?
  status       AgentOperationalStatus?
  payloadJson  Json?
  actorId      String?
  createdAt    DateTime                @default(now())

  @@index([eventType])
  @@index([agentWorldId])
  @@index([domainLayer])
  @@index([createdAt])
}

/* ==========================================================================
 * WYWO — While You Were Out (wywo.keyra.ie)
 * Trusted message layer for verified humans + verified agents.
 * Indexed against the Ciright identity hierarchy (subscription_id, eid, uid,
 * world_id, keyra_identity_id) and the Keyra trust graph.
 * ==========================================================================
 */

enum WywoTrustStatus {
  TRUSTED
  FAMILY_CIRCLE
  EXECUTIVE_RING
  REFERRED
  PENDING_REVIEW
  UNKNOWN
  BLOCKED
  SUPPRESSED
  EXPIRED
  REVOKED
}

enum WywoTrustRing {
  FAMILY_CIRCLE
  EXECUTIVE_RING
  TRUSTED_CONTACTS
  REFERRED_CONTACTS
  PENDING_UNKNOWNS
  BLOCKED_ENTITIES
}

enum WywoMessageStatus {
  DRAFT
  QUEUED
  DELIVERED
  READ
  REPLIED
  PENDING_TRUST
  ARCHIVED
  BLOCKED
  EXPIRED
  REVOKED
}

enum WywoInviteStatus {
  PENDING
  SMS_SENT
  CLICKED
  VERIFIED
  EXPIRED
  REVOKED
}

enum WywoWorldType {
  PERSONAL
  FAMILY
  ENTERPRISE
  SUBSCRIPTION
  AGENT
}

/** Personal / enterprise WYWO world bound to Ciright subscription identity. */
model KeyraWywoWorld {
  id              String   @id @default(cuid())
  worldId         String   @unique
  ownerPhoneE164  String
  ownerUid        String?
  subscriptionId  String?
  eid             String?
  keyraIdentityId String?
  name            String?
  email           String?
  company         String?
  role            String?
  country         String?
  preferredDevice String?
  notificationRulesJson Json @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([ownerPhoneE164, worldId])
  @@index([ownerPhoneE164])
  @@index([subscriptionId])
  @@map("keyra_wywo_worlds")
}

/** Global Keyra WYWO message table — mirrored into Ciright Core. */
model KeyraWywoMessage {
  id               String            @id @default(cuid())
  wywoMessageId    String            @unique @default(cuid())
  subscriptionId   String?
  eid              String?
  uid              String?
  worldId          String?
  keyraIdentityId  String?
  fromWorldId      String?
  toWorldId        String?

  senderUid        String?
  senderKeyraId    String?
  senderName       String?
  senderPhone      String
  recipientUid     String?
  recipientKeyraId String?
  recipientName    String?
  recipientPhone   String
  recipientEmail   String?

  ccRecipientsJson Json              @default("[]")
  subject          String
  bodyEncrypted    String            @db.Text
  bodyCryptoJson     Json?
  attachmentsJson  Json              @default("[]")

  priority         String            @default("normal")
  category         String?
  trustStatus      WywoTrustStatus   @default(UNKNOWN)
  messageStatus    WywoMessageStatus @default(QUEUED)
  referralRequired Boolean           @default(false)
  referralPhoneNumber String?
  inviteToken      String?
  inviteStatus     WywoInviteStatus?

  urgent           Boolean           @default(false)
  readReceiptRequested Boolean         @default(false)
  replyPermitted   Boolean           @default(true)
  expiresAt        DateTime?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deliveredAt      DateTime?
  readAt           DateTime?
  approvedAt       DateTime?
  blockedAt        DateTime?
  archivedAt       DateTime?

  invites KeyraWywoInvite[]
  audits  KeyraWywoAuditLog[]

  @@index([senderPhone])
  @@index([recipientPhone])
  @@index([trustStatus])
  @@index([messageStatus])
  @@index([worldId])
  @@index([subscriptionId])
  @@map("keyra_wywo_messages")
}

/** Owner ↔ contact trust graph — controls who is allowed to send what. */
model KeyraWywoContactTrust {
  id             String          @id @default(cuid())
  ownerPhoneE164 String
  ownerUid       String?
  contactPhone   String
  contactUid     String?
  contactName    String?
  trustStatus    WywoTrustStatus @default(PENDING_REVIEW)
  trustRing      WywoTrustRing   @default(PENDING_UNKNOWNS)
  referralUid    String?
  referralPhone  String?
  approvedByUid  String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([ownerPhoneE164, contactPhone])
  @@index([ownerPhoneE164])
  @@index([ownerUid])
  @@index([trustRing])
  @@index([trustStatus])
  @@map("keyra_wywo_contact_trust")
}

/** Onboarding invites — SMS deep-link tokens for unknown recipients. */
model KeyraWywoInvite {
  id              String           @id @default(cuid())
  inviteToken     String           @unique
  messageId       String
  senderUid       String?
  senderPhoneE164 String
  recipientPhone  String
  recipientName   String?
  worldId         String?
  subscriptionId  String?
  status          WywoInviteStatus @default(PENDING)
  smsSentAt       DateTime?
  clickedAt       DateTime?
  verifiedAt      DateTime?
  expiredAt       DateTime?
  expiresAt       DateTime
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  message KeyraWywoMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([recipientPhone])
  @@index([status])
  @@index([senderPhoneE164])
  @@map("keyra_wywo_invites")
}

/** Append-only audit log — every state transition on a WYWO message. */
model KeyraWywoAuditLog {
  id           String            @id @default(cuid())
  messageId    String?
  actorUid     String?
  actorPhone   String?
  action       String
  oldValueJson Json?
  newValueJson Json?
  ipAddress    String?
  deviceId     String?
  createdAt    DateTime          @default(now())

  message KeyraWywoMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([actorPhone])
  @@index([createdAt])
  @@index([action])
  @@map("keyra_wywo_audit_log")
}
