generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeploymentStatus {
  IDENTIFIED
  INSTITUTIONAL_AWARENESS
  TVIP
  OPERATIONAL
}

enum TargetType {
  COUNTRY
  TELCO
}

enum ServerEnvironment {
  PROD
  STAGE
  TEST
}

enum VerificationMethod {
  EMAIL_OTP
  SSO
  INVITE_ONLY
}

enum EmployeeType {
  TYPE_1
}

enum RequestVerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

enum RequestApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StatusHistoryTargetType {
  REGION
  COUNTRY
  TELCO
  SERVER_NODE
}

/** Mirrors institutional roles from the deployment doctrine (v1). */
enum DeploymentAdminRole {
  GLOBAL_ADMIN
  REGIONAL_ADMIN
  COUNTRY_ADMIN
  TELCO_ADMIN
  COMPLIANCE_REVIEWER
  READ_ONLY
}

model AdminUser {
  id           String               @id @default(cuid())
  email        String               @unique
  displayName  String?
  passwordHash String
  role         DeploymentAdminRole
  /** JSON: { "regionIds"?: string[], "countryIds"?: string[], "telcoIds"?: string[] } */
  scopeJson    Json?
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model Region {
  id             String   @id @default(cuid())
  continentCode  String
  subregionCode  String
  name           String
  slug           String   @unique
  mapKey         String
  sortOrder      Int      @default(0)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  countries CountryDeployment[]
}

model CountryDeployment {
  id                      String            @id @default(cuid())
  regionId                String
  region                  Region            @relation(fields: [regionId], references: [id], onDelete: Cascade)
  name                    String
  iso2                    String
  iso3                    String
  flagAssetKey            String
  population              Int?
  populationDisplay       String?
  countrySubdomain        String
  officialReferenceDomain String?
  status                  DeploymentStatus
  statusNote              String?
  sourceLabel             String?
  sourceUrl               String?
  sourceVerifiedAt        DateTime?
  sortOrder               Int               @default(0)
  isPublished             Boolean           @default(false)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  telcos TelcoDeployment[]

  @@unique([countrySubdomain])
  @@index([regionId])
  @@index([iso2])
}

model TelcoDeployment {
  id                 String            @id @default(cuid())
  countryId          String
  country            CountryDeployment @relation(fields: [countryId], references: [id], onDelete: Cascade)
  name               String
  slug               String
  subscribers        Int?
  subscribersDisplay String?
  telcoSubdomain     String
  officialDomain     String?
  status             DeploymentStatus
  statusNote         String?
  sourceLabel        String?
  sourceUrl          String?
  sourceVerifiedAt   DateTime?
  sortOrder          Int               @default(0)
  isPublished        Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([countryId, slug])
  @@index([countryId])
}

model ServerNode {
  id              String            @id @default(cuid())
  targetType      TargetType
  targetId        String
  fqdn            String
  environment     ServerEnvironment
  healthcheckUrl  String?
  status          DeploymentStatus
  lastHeartbeatAt DateTime?
  metadataJson    Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([targetType, targetId])
}

model AccessDomainRule {
  id                   String             @id @default(cuid())
  targetType           TargetType
  targetId             String
  allowedEmailDomain   String
  verificationMethod   VerificationMethod @default(EMAIL_OTP)
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([targetType, targetId])
}

model ServerAccessRequest {
  id                     String                    @id @default(cuid())
  targetType             TargetType
  targetId               String
  workEmail              String
  employeeType           EmployeeType              @default(TYPE_1)
  requestReason          String?
  verificationStatus     RequestVerificationStatus @default(PENDING)
  verificationTokenHash  String?
  verificationExpiresAt  DateTime?
  approvalStatus         RequestApprovalStatus     @default(PENDING)
  approvedBy             String?
  approvedAt             DateTime?
  rejectedBy             String?
  rejectedAt             DateTime?
  rejectionReason        String?
  auditRef               String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  @@index([targetType, targetId])
  @@index([workEmail])
}

model StatusHistory {
  id             String                   @id @default(cuid())
  targetType     StatusHistoryTargetType
  targetId       String
  previousStatus DeploymentStatus?
  nextStatus     DeploymentStatus
  changedBy      String
  changedAt      DateTime                 @default(now())
  reason         String?

  @@index([targetType, targetId])
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorId     String?
  actorRole   String?
  entityType  String
  entityId    String
  action      String
  payloadJson Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

/** Optional display profile for Keyra marketing / app session (keyed by phone from login). */
model KeyraSiteUserProfile {
  id          String   @id @default(cuid())
  phoneE164 String   @unique
  displayName String?
  email       String?
  country     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/** Admin-configured country weights for keyra.ie “Latest authentications” demo feed. */
model AuthenticationCountry {
  id                      String   @id @default(cuid())
  countryName             String
  officialName            String?  @db.Text
  iso2                    String   @unique @db.VarChar(2)
  iso3                    String?  @unique @db.VarChar(3)
  isoNumeric              String?  @db.VarChar(3)
  /** Broad area (e.g. Europe, Americas) — used for filters and feed region fallback. */
  region                  String
  subRegion               String?  @db.Text
  capitalCity             String?  @db.Text
  flagEmoji               String?  @db.VarChar(8)
  flagAssetPath           String?  @db.Text
  phoneCountryCode        String?  @db.VarChar(32)
  currencyCode            String?  @db.VarChar(3)
  currencyName            String?  @db.Text
  primaryLanguage         String?  @db.Text
  active                  Boolean  @default(true)
  /** When false, country is excluded from weighted feed selection (still visible in admin). */
  authenticationEnabled   Boolean  @default(true)
  /** Relative weight before normalization to 100% in the feed engine. Default 5 for global seed. */
  percentageWeight        Float    @default(5)
  displayPriority         Int      @default(0)
  notes                     String?  @db.Text
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([active, region])
  @@index([active, authenticationEnabled])
  @@index([subRegion])
  @@index([displayPriority])
}

/** SAT protocol rows for weighted demo feed + protocol detail modal (global SAT-Core registry). */
model SatProtocol {
  id                   String   @id @default(cuid())
  protocolName         String
  protocolCode         String   @unique
  /** URL-style slug (e.g. sat-mfa); not used in feed pair keys. */
  protocolSlug         String?  @unique
  protocolCategory     String
  shortDescription     String?  @db.Text
  longDescription      String?  @db.Text
  active               Boolean  @default(true)
  /** Feed selection weight (normalized with other active protocols). */
  percentageWeight     Float    @default(60)
  protocolMemo         String   @default("")
  protocolUrlEnabled   Boolean  @default(false)
  protocolUrl          String?
  allowProtocolLink    Boolean  @default(false)
  /** Home vs roaming split for H/R display (must sum to ~100). Default 40 / 60. */
  homePercentage        Float    @default(40)
  roamingPercentage     Float    @default(60)
  securityClassification String  @default("STANDARD") @db.VarChar(24)
  flagEnterprise        Boolean  @default(true)
  flagGovernment        Boolean  @default(true)
  flagTelco             Boolean  @default(true)
  flagConsumer          Boolean  @default(true)
  flagAiAgent           Boolean  @default(true)
  displayOrder          Int      @default(0)
  iconKey               String?  @db.VarChar(64)
  colorTheme            String?  @db.VarChar(32)
  /** 1–5 scale for admin / UI trust badge. */
  trustLevel            Int      @default(4)
  riskReductionScore    Int      @default(0)
  globalAvailability    Boolean  @default(true)
  apiReady              Boolean  @default(true)
  auditRequired         Boolean  @default(true)
  consentRequired       Boolean  @default(true)
  zeroKnowledgeCompatible Boolean @default(false)
  simOrEsimRequired     Boolean  @default(false)
  deviceBindingRequired Boolean  @default(false)
  createdBySystem       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([active])
  @@index([protocolCategory])
  @@index([displayOrder])
}

/** Singleton row — use id "default" in application code. */
model AuthenticationFeedSetting {
  id                       String   @id
  feedEnabled              Boolean  @default(true)
  initialRecordsCount      Int      @default(50)
  batchSize                Int      @default(50)
  fetchThreshold             Int      @default(30)
  sessionUniquenessLimit     Int      @default(2000)
  maskingEnabled           Boolean  @default(true)
  obfuscationEnabled       Boolean  @default(false)
  maxRecordsPerSession     Int      @default(50000)
  animationSpeedMs       Int      @default(400)
  refreshBehavior          String   @default("append")
  defaultRegionWeightPreset String? @db.Text
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

/** Server-side session for paginated / weighted auth feed generation. */
model AuthenticationFeedSession {
  id                    String   @id @default(cuid())
  sessionUuid           String   @unique
  userFingerprintHash   String?
  renderedCount         Int      @default(0)
  uniquenessEpoch       Int      @default(0)
  pairsUsedJson         Json     @default("[]")
  rngNonce              Int      @default(0)
  createdAt             DateTime @default(now())
  expiresAt             DateTime

  @@index([expiresAt])
}
